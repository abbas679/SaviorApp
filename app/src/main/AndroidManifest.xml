<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Needed to fetch the user's current location for the alert message -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Needed to send the emergency SMS to the saved contacts -->
    <uses-permission android:name="android.permission.SEND_SMS" />

    <!-- Needed to silence the ringer instantly when an emergency is triggered,
         so a call-back doesn't ring out loud and expose the user's situation -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Savior"
        android:supportsRtl="true"
        android:theme="@style/Theme.Savior">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Savior">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
